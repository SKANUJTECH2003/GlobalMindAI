# GlobalMindAI Environment Configuration
# Copy this file to .env and edit with your values

# ===== Model Configuration =====
# LLM Model ID (Text generation)
VITE_LLM_MODEL_ID=Xenova/LFM2-350M

# VLM Model ID (Vision language model)
VITE_VLM_MODEL_ID=Xenova/LFM2-VL-450M

# Speech-to-Text Model
VITE_WHISPER_MODEL=Xenova/whisper-tiny

# Text-to-Speech Model
VITE_PIPER_MODEL=en_US-hfc_female-medium

# ===== API Configuration =====
# API endpoint (if using backend services)
VITE_API_ENDPOINT=http://localhost:3000

# API timeout in milliseconds
VITE_API_TIMEOUT=30000

# ===== File Upload Configuration =====
# Maximum file size in bytes (50MB default)
VITE_MAX_FILE_SIZE=52428800

# Allowed file types (comma-separated)
VITE_ALLOWED_FILE_TYPES=pdf,jpg,png,webp,txt

# ===== Generation Configuration =====
# Timeout for text generation (milliseconds)
VITE_TEXT_GENERATION_TIMEOUT=180000

# Timeout for VLM operations (milliseconds)
VITE_VLM_TIMEOUT=120000

# Default temperature for LLM (0.0 - 1.0)
# Lower = more deterministic, Higher = more creative
VITE_DEFAULT_TEMPERATURE=0.7

# Maximum tokens to generate per request
VITE_MAX_TOKENS=512

# ===== Application Configuration =====
# Environment (development, staging, production)
VITE_ENVIRONMENT=development

# Enable debug logging
VITE_DEBUG_LOGGING=false

# Enable analytics
VITE_ENABLE_ANALYTICS=false

# ===== Feature Flags =====
# Enable voice input/output
VITE_ENABLE_VOICE=true

# Enable vision/image analysis
VITE_ENABLE_VISION=true

# Enable offline mode
VITE_ENABLE_OFFLINE=false

# ===== Logging =====
# Log level (error, warn, info, debug)
VITE_LOG_LEVEL=info

# Enable persistent logging to storage
VITE_PERSISTENT_LOGGING=true

# ===== Performance =====
# Debounce interval for UI updates (milliseconds)
VITE_UPDATE_DEBOUNCE_MS=100

# Streaming yield interval (milliseconds)
VITE_STREAM_YIELD_MS=50

# ===== Development Only =====
# Enable HMR (Hot Module Replacement)
VITE_HMR_ENABLED=true

# Source maps in development
VITE_SOURCE_MAPS=true
